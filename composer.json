{
    "name": "ksfraser/ksf-calendar",
    "description": "Unified calendar system - aggregates PM tasks, CRM activities, HRM time tracking, client dates. iCal import/export, multi-calendar filter, FullCalendar.js ready. Replicates/replaces SuiteCRM, vTiger, WebCalendar calendar views.",
    "type": "library",
    "license": "GPL-3.0",
    "keywords": [
        "calendar",
        "ical",
        "icalendar",
        "fullcalendar",
        "dotproject",
        "suitecrm",
        "vtiger",
        "frontaccounting",
        "weberp",
        "ksf"
    ],
    "authors": [
        {
            "name": "KSFII Development Team",
            "email": "dev@ksfii.org"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "eluceo/ical": "^2.0",
        "ksfraser/exceptions": "^1.3",
        "ksfraser/file": "*",
        "ksfraser/genericinterface": "*",
        "ksfraser/ksf-schemamanager": "*",
        "ksfraser/validation": "*",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "*",
        "psr/log": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\": "src/Ksfraser/"
        },
        "classmap": [
            "src/Ksfraser/Calendar/Event/CalendarEntryEvents.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpdoc": "phpdocumentor",
        "phpstan": "phpstan analyse src --level=8",
        "phpcs": "phpcs --standard=PSR12 src tests",
        "ci": [
            "@phpstan",
            "@phpcs",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
"repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/Exceptions"
        },
        {
            "type": "composer",
            "url": "https://packagist.org",
            "canonical": false
        },
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/ksf_SchemaManager"
        },
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/FILE"
        }
    ]
}